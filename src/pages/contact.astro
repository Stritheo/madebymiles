---
import Base from '@/layouts/Base.astro';
import CTA from '@/components/CTA.astro';
import { SITE } from '@/site.config';
---

<Base
  title="Contact | Miles Sowden"
  description="Connect with Miles Sowden via LinkedIn or WhatsApp for executive roles, board positions and advisory work."
>
  <section class="pt-48 pb-32 max-md:pt-32 max-md:pb-20">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h1 class="font-display text-[3.5rem] max-lg:text-5xl max-md:text-[2.5rem] leading-[1.1] tracking-[-0.02em] text-text-primary mb-6">
        Contact
      </h1>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mb-16">
        Three ways to reach me. Pick whichever suits you.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- LinkedIn -->
        <div class="flex flex-col p-10 max-md:p-8 bg-bg-card border-t-[3px] border-text-accent">
          <h2 class="font-display text-2xl text-text-primary mb-3">LinkedIn</h2>
          <p class="text-base text-text-secondary mb-6">For professional introductions and conversations about roles, advisory or board opportunities.</p>
          <div class="mt-auto">
            <CTA href={SITE.linkedIn} size="sm" external>
              Connect on LinkedIn
            </CTA>
          </div>
        </div>

        <!-- WhatsApp -->
        <div class="flex flex-col p-10 max-md:p-8 bg-bg-card border-t-[3px] border-text-accent">
          <h2 class="font-display text-2xl text-text-primary mb-3">WhatsApp</h2>
          <p class="text-base text-text-secondary mb-6">For a quicker, more direct conversation.</p>
          <div class="mt-auto">
            <CTA href={SITE.whatsApp.link('Hi Miles, I found your site and would like to connect.')} size="sm" external>
              Open WhatsApp
            </CTA>
          </div>
        </div>

        <!-- Send a note -->
        <div class="flex flex-col p-10 max-md:p-8 bg-bg-card border-t-[3px] border-text-accent">
          <h2 class="font-display text-2xl text-text-primary mb-3">Send a note</h2>
          <p class="text-base text-text-secondary mb-4">Leave your details. I will be in touch within 24 hours.</p>
          <div class="mt-auto">
            <input
              type="text"
              id="contact-name"
              placeholder="Your name"
              class="w-full px-3 py-2 text-sm text-text-primary bg-white border-[1.5px] border-border-light rounded-lg focus:outline-none focus:border-text-accent transition-colors duration-200 mb-2"
            />
            <input
              type="email"
              id="contact-email"
              placeholder="Your email"
              class="w-full px-3 py-2 text-sm text-text-primary bg-white border-[1.5px] border-border-light rounded-lg focus:outline-none focus:border-text-accent transition-colors duration-200 mb-3"
            />
            <button
              id="contact-send-btn"
              disabled
              class="inline-flex items-center justify-center w-full px-5 py-2.5 text-sm font-medium no-underline rounded-lg transition-all duration-250 bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-bg-dark-hover hover:border-bg-dark-hover hover:-translate-y-px disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:translate-y-0 cursor-pointer"
            >
              Send
            </button>
            <p id="contact-status" class="text-xs mt-2 hidden"></p>
          </div>
        </div>
      </div>

      <div class="mt-20">
        <h2 class="font-display text-[2.5rem] max-md:text-[2rem] leading-[1.2] tracking-[-0.02em] text-text-primary mb-6">
          Role fit
        </h2>
        <ul class="text-lg leading-relaxed text-text-secondary space-y-3 list-none pl-0">
          <li class="border-l-[3px] border-text-accent pl-4">CEO, CCO and COO roles in insurance and financial services</li>
          <li class="border-l-[3px] border-text-accent pl-4">Non-executive director appointments</li>
          <li class="border-l-[3px] border-text-accent pl-4">Advisory and consulting engagements</li>
        </ul>
      </div>
      <div class="mt-12">
        <CTA href="/fit" variant="secondary" size="sm">
          Try the Fit Finder for a detailed skill assessment
        </CTA>
      </div>
    </div>
  </section>

  <script>
    const contactName = document.getElementById('contact-name') as HTMLInputElement;
    const contactEmail = document.getElementById('contact-email') as HTMLInputElement;
    const contactSendBtn = document.getElementById('contact-send-btn') as HTMLButtonElement;
    const contactStatus = document.getElementById('contact-status')!;

    function validateContact() {
      const name = contactName.value.trim();
      const email = contactEmail.value.trim();
      contactSendBtn.disabled = !(name.length > 0 && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email));
    }

    contactName.addEventListener('input', validateContact);
    contactEmail.addEventListener('input', validateContact);

    contactSendBtn.addEventListener('click', async () => {
      const name = contactName.value.trim();
      const email = contactEmail.value.trim();
      if (!name || !email) return;

      contactSendBtn.disabled = true;
      contactSendBtn.textContent = 'Sending...';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email }),
        });

        if (!res.ok) throw new Error('Failed to send');

        contactStatus.textContent = 'Sent. I will be in touch within 24 hours.';
        contactStatus.className = 'text-xs mt-2 text-text-accent';
        contactStatus.classList.remove('hidden');
        contactSendBtn.textContent = 'Sent';
        contactName.disabled = true;
        contactEmail.disabled = true;
      } catch {
        contactStatus.textContent = 'Could not send. Please try LinkedIn or WhatsApp instead.';
        contactStatus.className = 'text-xs mt-2 text-red-600';
        contactStatus.classList.remove('hidden');
        contactSendBtn.textContent = 'Send';
        contactSendBtn.disabled = false;
      }
    });
  </script>
</Base>
