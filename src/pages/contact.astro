---
import Base from '@/layouts/Base.astro';
import CTA from '@/components/CTA.astro';
---

<Base
  title="Contact | Miles Sowden"
  description="Contact with Miles Sowden via LinkedIn or WhatsApp. Open to executive roles, board positions and advisory work."
>
  <section class="pt-48 pb-32 max-md:pt-32 max-md:pb-20">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h1 class="font-display text-[3.5rem] max-lg:text-5xl max-md:text-[2.5rem] leading-[1.1] tracking-[-0.02em] text-text-primary mb-6">
        Contact
      </h1>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mb-16 max-w-[720px]">
        I prefer direct conversations over contact forms. The two best ways to reach me are LinkedIn and WhatsApp.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-[720px]">
        <!-- LinkedIn -->
        <div class="flex flex-col p-10 max-md:p-8 bg-bg-card border-t-[3px] border-text-accent">
          <h2 class="font-display text-2xl text-text-primary mb-3">LinkedIn</h2>
          <p class="text-base text-text-secondary mb-6">For professional introductions and conversations about roles, advisory or board opportunities.</p>
          <div class="mt-auto">
            <CTA href="https://www.linkedin.com/in/milessowden" size="sm">
              Connect on LinkedIn
            </CTA>
          </div>
        </div>

        <!-- WhatsApp -->
        <div class="flex flex-col p-10 max-md:p-8 bg-bg-card border-t-[3px] border-text-accent">
          <h2 class="font-display text-2xl text-text-primary mb-3">WhatsApp</h2>
          <p class="text-base text-text-secondary mb-6">For a quicker, more direct conversation.</p>
          <div class="mt-auto">
            <CTA href="https://wa.me/61414185721?text=Hi%20Miles%2C%20I%20found%20your%20site%20and%20would%20like%20to%20connect." size="sm">
              Open WhatsApp
            </CTA>
          </div>
        </div>
      </div>

      <div class="mt-20 max-w-[720px]">
        <h2 class="font-display text-[2.5rem] max-md:text-[2rem] leading-[1.2] tracking-[-0.02em] text-text-primary mb-6">
          What I am open to
        </h2>
        <ul class="text-lg leading-relaxed text-text-secondary space-y-3 list-none pl-0">
          <li>CEO and CXO roles in insurance and financial services</li>
          <li>Non-executive director appointments</li>
          <li>Advisory and consulting engagements</li>
        </ul>
      </div>
    </div>
  </section>
</Base>
