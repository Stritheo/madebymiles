---
import Base from '@/layouts/Base.astro';
import CTA from '@/components/CTA.astro';
import Card from '@/components/Card.astro';
---

<Base title="Miles Sowden | Executive Leader">
  <!-- Hero -->
  <section class="pt-48 pb-40 max-md:pt-32 max-md:pb-24">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h1 class="font-display text-[4rem] max-lg:text-5xl max-md:text-4xl leading-[1.1] tracking-[-0.02em] text-text-primary mb-10 max-w-[900px]">
        Senior insurance executive improving customer outcomes and unit costs
      </h1>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mb-12 max-w-[800px]">
        I help insurers improve customer experience at a lower unit cost by building purpose-led, accountable teams and using data, technology and AI in impactful ways.
      </p>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mb-12 max-w-[800px]">
        Twenty years delivering outcomes across Suncorp, Westpac, Commonwealth Bank, Hollard and Strata Community Insurance through strategic clarity, large-scale leadership and cultural uplift.
      </p>
      <div class="flex gap-4 flex-wrap max-md:flex-col">
        <CTA href="https://www.linkedin.com/messaging/compose/?to=milessowden">
          Message me on LinkedIn
        </CTA>
        <CTA href="#projects" variant="secondary" external={false}>
          View my work
        </CTA>
      </div>
    </div>
  </section>

  <!-- What I do -->
  <section class="py-32 max-md:py-20">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h2 class="font-display text-5xl max-lg:text-4xl max-md:text-[2rem] leading-[1.2] tracking-[-0.02em] text-text-primary">
        What I do
      </h2>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mt-6 max-w-[800px]">
        I modernise products, improve pricing and claims, build teams and deliver end-to-end change across insurance businesses.
      </p>
      <div class="grid grid-cols-2 max-md:grid-cols-1 gap-6 mt-16">
        <div class="p-12 max-md:p-8 bg-bg-card border-l-[3px] border-text-accent transition-all duration-300 hover:translate-x-1 hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)]">
          <h3 class="font-display text-[2rem] max-md:text-2xl leading-[1.3] tracking-[-0.01em] text-text-primary mb-4">Product Modernisation</h3>
          <p class="text-lg leading-relaxed text-text-secondary">Redesign insurance products to improve access to cover, affordability and customer clarity while maintaining underwriting discipline.</p>
        </div>
        <div class="p-12 max-md:p-8 bg-bg-card border-l-[3px] border-text-accent transition-all duration-300 hover:translate-x-1 hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)]">
          <h3 class="font-display text-[2rem] max-md:text-2xl leading-[1.3] tracking-[-0.01em] text-text-primary mb-4">Pricing and Claims</h3>
          <p class="text-lg leading-relaxed text-text-secondary">Build pricing engines and claims workflows that balance customer fairness with financial sustainability.</p>
        </div>
        <div class="p-12 max-md:p-8 bg-bg-card border-l-[3px] border-text-accent transition-all duration-300 hover:translate-x-1 hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)]">
          <h3 class="font-display text-[2rem] max-md:text-2xl leading-[1.3] tracking-[-0.01em] text-text-primary mb-4">Team and Culture</h3>
          <p class="text-lg leading-relaxed text-text-secondary">Develop purpose-led, accountable teams through clear strategy, strong capability development and cultural alignment.</p>
        </div>
        <div class="p-12 max-md:p-8 bg-bg-card border-l-[3px] border-text-accent transition-all duration-300 hover:translate-x-1 hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)]">
          <h3 class="font-display text-[2rem] max-md:text-2xl leading-[1.3] tracking-[-0.01em] text-text-primary mb-4">End-to-End Change</h3>
          <p class="text-lg leading-relaxed text-text-secondary">Deliver transformation programs spanning products, operations, technology and people across complex organisations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Work and impact -->
  <section class="py-32 max-md:py-20" id="projects">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h2 class="font-display text-5xl max-lg:text-4xl max-md:text-[2rem] leading-[1.2] tracking-[-0.02em] text-text-primary">
        Work and impact
      </h2>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mt-6 max-w-[800px]">
        Two decades delivering performance uplift, AI transformation, strategic alliances and cultural change across major Australian financial institutions.
      </p>
      <div class="grid grid-cols-2 max-md:grid-cols-1 gap-8 mt-16">
        <Card
          title="Strata Community Insurance"
          description="GM Data and Technology Solutions. Deployed digital channels, sophisticated pricing, AI and automation. Cleared backlog of 30,000 tasks, reduced underwriting cycle time by 19%, achieved 76% staff engagement score."
          tags={['AI', 'Automation', 'Digital']}
        />
        <Card
          title="Commonwealth Bank"
          description="GM General Insurance. Led $1bn insurer with 700 staff serving one million customers. Developed rating factor reducing premiums by 10% and improving the loss ratio by 1%. Increased digital sales to 70%."
          tags={['Leadership', 'Pricing', 'Digital']}
        />
        <Card
          title="Hollard Insurance"
          description="Chief Revenue Officer. Established 15-year strategic alliance with CBA for one million customers. Led transition and portfolio transformation to meet target returns and risk appetite."
          tags={['Alliances', 'Strategy', 'Portfolio']}
        />
        <Card
          title="Westpac Banking Corporation"
          description="Senior Manager roles. Established distribution plan and operating model for Westpac-Allianz alliance. Doubled written premiums and increased NPS to +44 from +25."
          tags={['Partnerships', 'Distribution', 'NPS']}
        />
      </div>
    </div>
  </section>

  <!-- Advisory -->
  <section class="py-32 max-md:py-20 bg-bg-dark text-white">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h2 class="font-display text-5xl max-lg:text-4xl max-md:text-[2rem] leading-[1.2] tracking-[-0.02em] text-white">
        Advisory
      </h2>
      <p class="text-xl max-md:text-lg leading-relaxed text-white/90 mt-6 max-w-[800px]">
        Strategic advisory focused on outcomes across strategy, risk, operations, technology and AI for insurance businesses and boards.
      </p>
      <p class="text-xl max-md:text-lg leading-relaxed text-white/90 mt-4 max-w-[800px]">
        Open to executive roles, equity opportunities, advisory work and board positions that align with improving customer outcomes and building sustainable insurance businesses.
      </p>
      <div class="flex gap-4 flex-wrap max-md:flex-col mt-12">
        <a href="https://www.linkedin.com/messaging/compose/?to=milessowden" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-10 py-4.5 text-base font-medium no-underline rounded-lg transition-all duration-250 bg-text-accent text-white hover:bg-[#B36F4F] hover:-translate-y-px">
          Start a conversation
        </a>
        <a href="https://linkedin.com/in/milessowden" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-10 py-4.5 text-base font-medium no-underline rounded-lg transition-all duration-250 bg-transparent text-white border-[1.5px] border-white/30 hover:border-white/50 hover:bg-white/10">
          View LinkedIn
        </a>
      </div>
    </div>
  </section>
</Base>
