---
import Base from '@/layouts/Base.astro';
---

<Base
  title="Fit Finder | Miles Sowden"
  description="Upload a role description and see how Miles Sowden's AICD skill matrix aligns to what the role requires."
>
  <section class="pt-48 pb-32 max-md:pt-32 max-md:pb-20">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h1 class="font-display text-[3.5rem] max-lg:text-5xl max-md:text-[2.5rem] leading-[1.1] tracking-[-0.02em] text-text-primary mb-6">
        Role Fit
      </h1>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mb-16 max-w-[720px]">
        Upload a role description or paste the text. The analysis matches requirements against an AICD-aligned skill matrix and twenty years of career evidence. Built the same way I approach any problem: structured data, clear framework, technology doing the heavy lifting.
      </p>

      <!-- State: Upload form -->
      <div id="state-upload">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <!-- File upload -->
          <div>
            <div
              id="drop-zone"
              class="flex flex-col items-center justify-center p-10 border-2 border-dashed border-border-light bg-bg-card rounded-lg cursor-pointer hover:border-text-accent transition-colors min-h-[200px]"
              role="region"
              aria-label="File upload area"
              tabindex="0"
            >
              <svg class="w-10 h-10 mb-4 text-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
              </svg>
              <p class="text-base text-text-secondary mb-1">Drop a PDF here or click to browse</p>
              <p id="file-name" class="text-sm text-text-accent font-medium hidden"></p>
              <input id="file-input" type="file" accept=".pdf,application/pdf" class="hidden" aria-label="Upload role description PDF" />
            </div>
          </div>

          <!-- Text paste -->
          <div>
            <textarea
              id="text-input"
              class="w-full min-h-[200px] p-6 border border-border-light bg-bg-card rounded-lg text-base text-text-primary resize-none focus:outline-none focus:border-text-accent transition-colors"
              placeholder="Or paste the role description here..."
              aria-label="Paste role description"
            ></textarea>
            <p id="char-hint" class="text-sm text-text-secondary mt-2 hidden">
              <span id="char-count">0</span>/100 characters minimum
            </p>
          </div>
        </div>

        <p class="text-sm text-text-secondary mb-6">
          Your document is sent encrypted to Anthropic's Claude API for analysis. It is not used to train models and is automatically deleted within 30 days.
          <a href="/privacy#fit-finder" class="text-text-accent hover:underline">Full privacy details</a>
        </p>

        <button
          id="analyse-btn"
          disabled
          class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-10 py-4.5 text-base bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26] hover:border-[#151A26] hover:-translate-y-px disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:translate-y-0"
        >
          Analyse fit
        </button>
      </div>

      <!-- State: Loading -->
      <div id="state-loading" class="hidden" aria-live="polite">
        <div class="flex flex-col items-center justify-center py-20">
          <p class="text-xl text-text-primary font-medium mb-2">Analysing role fit...</p>
          <p class="text-base text-text-secondary mb-6">This usually takes 15 to 25 seconds</p>
          <div class="w-full max-w-[400px] h-1.5 bg-border-light rounded-full overflow-hidden">
            <div id="progress-bar" class="h-full bg-text-accent rounded-full transition-all duration-500 ease-out" style="width: 0%"></div>
          </div>
          <p id="progress-percent" class="text-sm text-text-secondary mt-3">0%</p>
        </div>
      </div>

      <!-- State: Error -->
      <div id="state-error" class="hidden">
        <div class="p-8 bg-bg-card border-t-[3px] border-red-500 mb-8">
          <p class="text-lg text-text-primary mb-2 font-medium">Something went wrong</p>
          <p id="error-message" class="text-base text-text-secondary mb-6"></p>
          <button
            id="retry-btn"
            class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-5 py-2.5 text-sm bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26]"
          >
            Try again
          </button>
        </div>
      </div>

      <!-- State: Results -->
      <div id="state-results" class="hidden">
        <!-- Tier 1: Summary -->
        <div id="result-summary" class="p-8 bg-bg-card border-t-[3px] border-text-accent mb-8">
          <p id="result-role-title" class="text-sm text-text-secondary uppercase tracking-wider mb-2 hidden"></p>
          <p id="result-summary-text" class="text-lg text-text-primary leading-relaxed"></p>
        </div>

        <!-- Tier 1: Top match cards (visible) -->
        <div id="matches-visible" class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8"></div>

        <!-- Unlock Gate -->
        <div id="unlock-gate" class="mb-8">
          <div id="unlock-cta" class="flex flex-col items-center py-10 mb-8 border border-border-light rounded-lg bg-bg-card">
            <p class="text-lg text-text-primary leading-relaxed mb-2 max-w-[560px] text-center">
              The full evaluation and matched case studies are shared in conversation. The depth is there. It belongs in a discussion, not on a screen.
            </p>
            <div id="unlock-buttons" class="flex flex-wrap gap-4 mt-6">
              <button
                id="linkedin-unlock-btn"
                class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-8 py-3.5 text-base bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26] hover:border-[#151A26] hover:-translate-y-px"
              >
                Connect on LinkedIn
              </button>
              <a
                id="whatsapp-btn"
                href="https://wa.me/61414185721?text=I%20ran%20the%20Fit%20Finder%20and%20would%20welcome%20a%20conversation."
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-8 py-3.5 text-base bg-transparent text-text-primary border-[1.5px] border-border-light hover:border-[#D4D4D4] hover:bg-bg-card"
              >
                Open WhatsApp
              </a>
            </div>
            <!-- Post-connect choice (hidden until LinkedIn/WhatsApp clicked) -->
            <div id="unlock-choice" class="hidden mt-6">
              <p class="text-base text-text-secondary mb-4 text-center">I've connected. Show me:</p>
              <div class="flex flex-wrap gap-4 justify-center">
                <button
                  id="show-matrix-btn"
                  class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-6 py-3 text-base bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26]"
                >
                  The full skill evaluation
                </button>
                <button
                  id="show-cases-btn"
                  class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-6 py-3 text-base bg-transparent text-text-primary border-[1.5px] border-border-light hover:border-[#D4D4D4] hover:bg-bg-card"
                >
                  The matched case studies
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Tier 2: AICD Skill Matrix -->
        <div id="skill-matrix-section" class="mb-8">
          <h2 class="font-display text-2xl text-text-primary mb-6">AICD Skill Matrix Evaluation</h2>
          <div id="skill-matrix" class="space-y-6"></div>
          <button id="also-matrix-btn" class="hidden text-sm text-text-accent hover:underline mt-4">
            Also available: full skill evaluation
          </button>
        </div>

        <!-- Tier 3: Matched Case Studies -->
        <div id="case-studies-section" class="mb-8">
          <h2 class="font-display text-2xl text-text-primary mb-6">Matched Case Studies</h2>
          <div id="case-studies" class="space-y-6"></div>
          <button id="also-cases-btn" class="hidden text-sm text-text-accent hover:underline mt-4">
            Also available: matched case studies
          </button>
        </div>

        <!-- Post-unlock footer -->
        <div class="flex flex-col items-center py-8 mb-8">
          <p class="text-lg text-text-primary mb-6">Good outcomes start with good conversations.</p>
          <div class="flex flex-wrap gap-4">
            <a
              href="https://www.linkedin.com/in/milessowden"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-8 py-3.5 text-base bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26] hover:border-[#151A26] hover:-translate-y-px"
            >
              Connect on LinkedIn
            </a>
            <a
              href="https://wa.me/61414185721?text=Hi%20Miles%2C%20I%20used%20Fit%20Finder%20and%20would%20like%20to%20connect."
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-8 py-3.5 text-base bg-transparent text-text-primary border-[1.5px] border-border-light hover:border-[#D4D4D4] hover:bg-bg-card"
            >
              Open WhatsApp
            </a>
          </div>
        </div>

        <!-- Share link -->
        <div class="flex items-center gap-3">
          <button
            id="share-btn"
            class="text-sm text-text-secondary hover:text-text-primary transition-colors"
          >
            Share this result
          </button>
          <span id="share-confirmation" class="text-sm text-text-accent hidden">Link copied</span>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const API_BASE = '/api/fit';

  // Elements
  const stateUpload = document.getElementById('state-upload')!;
  const stateLoading = document.getElementById('state-loading')!;
  const stateError = document.getElementById('state-error')!;
  const stateResults = document.getElementById('state-results')!;
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const fileName = document.getElementById('file-name')!;
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const analyseBtn = document.getElementById('analyse-btn') as HTMLButtonElement;
  const errorMessage = document.getElementById('error-message')!;
  const retryBtn = document.getElementById('retry-btn')!;
  const resultRoleTitle = document.getElementById('result-role-title')!;
  const resultSummary = document.getElementById('result-summary-text')!;
  const matchesVisible = document.getElementById('matches-visible')!;
  const unlockGate = document.getElementById('unlock-gate')!;
  const unlockButtons = document.getElementById('unlock-buttons')!;
  const unlockChoice = document.getElementById('unlock-choice')!;
  const linkedinUnlockBtn = document.getElementById('linkedin-unlock-btn')!;
  const showMatrixBtn = document.getElementById('show-matrix-btn')!;
  const showCasesBtn = document.getElementById('show-cases-btn')!;
  const skillMatrixSection = document.getElementById('skill-matrix-section')!;
  const skillMatrixContainer = document.getElementById('skill-matrix')!;
  const caseStudiesSection = document.getElementById('case-studies-section')!;
  const caseStudiesContainer = document.getElementById('case-studies')!;
  const alsoMatrixBtn = document.getElementById('also-matrix-btn')!;
  const alsoCasesBtn = document.getElementById('also-cases-btn')!;
  const shareBtn = document.getElementById('share-btn')!;
  const shareConfirmation = document.getElementById('share-confirmation')!;
  const charHint = document.getElementById('char-hint')!;
  const charCount = document.getElementById('char-count')!;

  let selectedFile: File | null = null;
  let currentToken: string | null = null;
  let progressInterval: ReturnType<typeof setInterval> | null = null;

  const progressBar = document.getElementById('progress-bar')!;
  const progressPercent = document.getElementById('progress-percent')!;

  function startProgress() {
    let progress = 0;
    progressBar.style.width = '0%';
    progressPercent.textContent = '0%';
    progressInterval = setInterval(() => {
      progress += (90 - progress) * 0.025;
      const rounded = Math.min(Math.round(progress), 90);
      progressBar.style.width = `${rounded}%`;
      progressPercent.textContent = `${rounded}%`;
    }, 200);
  }

  function finishProgress() {
    if (progressInterval) clearInterval(progressInterval);
    progressBar.style.width = '100%';
    progressPercent.textContent = '100%';
  }

  // Check for shared URL token
  const urlToken = new URLSearchParams(window.location.search).get('token');
  if (urlToken) {
    loadSharedResult(urlToken);
  }

  // --- Interfaces ---

  interface SkillMatrixEntry {
    aicdDomain: string;
    skillArea: string;
    relevance: 'primary' | 'supporting' | 'noted';
    matchReason: string;
    evidence: string;
    evidenceQualitative: string;
    confidence: 'high' | 'medium' | 'low';
  }

  interface CaseStudyMatch {
    company: string;
    role: string;
    descriptor: string;
    relevanceReason: string;
    fullContent: string;
  }

  // Legacy format for backwards compatibility
  interface LegacyMatch {
    rank: number;
    category: 'skillset' | 'mindset';
    aicdDomain: string;
    skillArea: string;
    matchReason: string;
    evidence: string;
    confidence: 'high' | 'medium' | 'low';
  }

  // --- Event listeners ---

  // Drag and drop
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-text-accent', 'bg-bg-primary');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-text-accent', 'bg-bg-primary');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-text-accent', 'bg-bg-primary');
    const file = e.dataTransfer?.files[0];
    if (file) handleFileSelect(file);
  });

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      fileInput.click();
    }
  });

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) handleFileSelect(file);
  });

  // Text input
  textInput.addEventListener('input', updateButtonState);

  // Analyse
  analyseBtn.addEventListener('click', analyse);

  // Retry
  retryBtn.addEventListener('click', () => {
    showState('upload');
  });

  // Unlock flow
  linkedinUnlockBtn.addEventListener('click', () => {
    window.open('https://www.linkedin.com/messaging/compose/?recipient=milessowden', '_blank');
    unlockButtons.classList.add('hidden');
    unlockChoice.classList.remove('hidden');
  });

  // WhatsApp click also shows choice
  document.getElementById('whatsapp-btn')!.addEventListener('click', () => {
    setTimeout(() => {
      unlockButtons.classList.add('hidden');
      unlockChoice.classList.remove('hidden');
    }, 500);
  });

  showMatrixBtn.addEventListener('click', () => {
    unblurSection('skill-matrix-section');
    alsoMatrixBtn.classList.add('hidden');
    alsoCasesBtn.classList.remove('hidden');
    unlockGate.classList.add('hidden');
    skillMatrixSection.scrollIntoView({ behavior: 'smooth' });
  });

  showCasesBtn.addEventListener('click', () => {
    unblurSection('case-studies-section');
    alsoCasesBtn.classList.add('hidden');
    alsoMatrixBtn.classList.remove('hidden');
    unlockGate.classList.add('hidden');
    caseStudiesSection.scrollIntoView({ behavior: 'smooth' });
  });

  alsoMatrixBtn.addEventListener('click', () => {
    unblurSection('skill-matrix-section');
    alsoMatrixBtn.classList.add('hidden');
    // Also swap evidence from qualitative to full
    swapEvidence('skill-matrix-section');
    skillMatrixSection.scrollIntoView({ behavior: 'smooth' });
  });

  alsoCasesBtn.addEventListener('click', () => {
    unblurSection('case-studies-section');
    alsoCasesBtn.classList.add('hidden');
    caseStudiesSection.scrollIntoView({ behavior: 'smooth' });
  });

  // Share
  shareBtn.addEventListener('click', () => {
    if (!currentToken) return;
    const url = new URL('/fit', window.location.origin);
    url.searchParams.set('token', currentToken);
    navigator.clipboard.writeText(url.toString()).then(() => {
      shareConfirmation.classList.remove('hidden');
      setTimeout(() => shareConfirmation.classList.add('hidden'), 3000);
    });
  });

  // --- Functions ---

  function handleFileSelect(file: File) {
    if (file.type !== 'application/pdf' && !file.name.endsWith('.pdf')) {
      showError('Only PDF files are accepted');
      return;
    }
    if (file.size > 5 * 1024 * 1024) {
      showError('File is too large (max 5MB)');
      return;
    }
    selectedFile = file;
    fileName.textContent = file.name;
    fileName.classList.remove('hidden');
    textInput.value = '';
    updateButtonState();
  }

  function updateButtonState() {
    const hasFile = selectedFile !== null;
    const trimmedLength = textInput.value.trim().length;
    const hasText = trimmedLength >= 100;
    analyseBtn.disabled = !hasFile && !hasText;
    if (trimmedLength > 0 && trimmedLength < 100 && !hasFile) {
      charCount.textContent = String(trimmedLength);
      charHint.classList.remove('hidden');
    } else {
      charHint.classList.add('hidden');
    }
    if (trimmedLength > 0) {
      selectedFile = null;
      fileName.classList.add('hidden');
    }
  }

  async function analyse() {
    showState('loading');
    startProgress();

    try {
      let response: Response;

      if (selectedFile) {
        const formData = new FormData();
        formData.append('file', selectedFile);
        response = await fetch(API_BASE, {
          method: 'POST',
          body: formData,
        });
      } else {
        response = await fetch(API_BASE, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: textInput.value.trim() }),
        });
      }

      if (!response.ok) {
        const err = await response.json() as { error?: string };
        throw new Error(err.error ?? `Request failed (${response.status})`);
      }

      const data = await response.json();

      finishProgress();

      // Handle new format
      if ('skillMatrix' in data) {
        renderResults(data, false);
      } else if ('matches' in data) {
        // Legacy format
        renderLegacyResults(data.matches, data.roleTitle, data.summary, data.token, false);
      }
    } catch (err) {
      finishProgress();
      showError(err instanceof Error ? err.message : 'Analysis failed. Please try again.');
    }
  }

  async function loadSharedResult(token: string) {
    showState('loading');
    startProgress();

    try {
      const response = await fetch(`${API_BASE}/verify?token=${encodeURIComponent(token)}`);
      if (!response.ok) {
        throw new Error('This result link has expired or is invalid.');
      }

      const data = await response.json();

      finishProgress();

      // Handle both formats for backwards compatibility
      if ('skillMatrix' in data) {
        renderResults({ ...data, token }, true);
      } else if ('matches' in data) {
        renderLegacyResults(data.matches, data.roleTitle, data.summary, token, true);
      }
    } catch (err) {
      finishProgress();
      showError(err instanceof Error ? err.message : 'Could not load shared result.');
    }
  }

  function renderResults(
    data: {
      skillMatrix: SkillMatrixEntry[];
      topMatches: { skillset: string; mindset: string };
      roleTitle: string | null;
      summary: string;
      relevantCaseStudies: CaseStudyMatch[];
      token: string;
    },
    isShared: boolean,
  ) {
    currentToken = data.token;

    // Summary
    if (data.roleTitle) {
      resultRoleTitle.textContent = data.roleTitle;
      resultRoleTitle.classList.remove('hidden');
    }
    resultSummary.textContent = data.summary;

    // Top match cards (Tier 1)
    const topSkillset = data.skillMatrix.find(e => e.skillArea === data.topMatches.skillset);
    const topMindset = data.skillMatrix.find(e => e.skillArea === data.topMatches.mindset);
    const topCards = [topSkillset, topMindset].filter(Boolean) as SkillMatrixEntry[];
    matchesVisible.innerHTML = topCards.map((entry, i) =>
      renderTopMatchCard(entry, i === 0 ? 'Skillset' : 'Mindset')
    ).join('');

    // Skill matrix (Tier 2)
    renderSkillMatrix(data.skillMatrix, data.topMatches, !isShared);

    // Case studies (Tier 3)
    caseStudiesContainer.innerHTML = data.relevantCaseStudies
      .map(cs => renderCaseStudyCard(cs, !isShared))
      .join('');

    if (isShared) {
      // Shared view: everything visible, no gate
      unlockGate.classList.add('hidden');
      alsoMatrixBtn.classList.add('hidden');
      alsoCasesBtn.classList.add('hidden');
    } else {
      // Normal view: gate visible, tiers blurred
      unlockGate.classList.remove('hidden');
    }

    showState('results');
  }

  function renderTopMatchCard(entry: SkillMatrixEntry, categoryLabel: string): string {
    const confidenceClass = entry.confidence === 'high'
      ? 'bg-text-accent text-white'
      : entry.confidence === 'medium'
        ? 'bg-bg-dark text-white'
        : 'bg-border-light text-text-primary';

    return `
      <div class="p-8 bg-bg-card border-t-[3px] border-text-accent">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-text-secondary uppercase tracking-wider">${entry.aicdDomain}</span>
          <span class="text-xs font-medium px-3 py-1 rounded ${confidenceClass}">${entry.confidence}</span>
        </div>
        <p class="text-xs text-text-accent uppercase tracking-wider font-medium mb-1">${categoryLabel} match</p>
        <h3 class="font-display text-xl text-text-primary mb-4">${entry.skillArea}</h3>
        <p class="text-base text-text-secondary mb-4"><strong class="text-text-primary">Why this matches:</strong> ${entry.matchReason}</p>
        <p class="text-base text-text-secondary"><strong class="text-text-primary">Evidence:</strong> ${entry.evidenceQualitative}</p>
      </div>
    `;
  }

  function renderSkillMatrix(
    matrix: SkillMatrixEntry[],
    topMatches: { skillset: string; mindset: string },
    blurred: boolean,
  ) {
    // Group by domain
    const domains = new Map<string, SkillMatrixEntry[]>();
    for (const entry of matrix) {
      const list = domains.get(entry.aicdDomain) ?? [];
      list.push(entry);
      domains.set(entry.aicdDomain, list);
    }

    let html = '';
    for (const [domain, entries] of domains) {
      html += `<div class="mb-4">`;
      html += `<h3 class="text-sm text-text-secondary uppercase tracking-wider font-medium mb-3 px-4">${domain}</h3>`;
      html += `<div class="space-y-2">`;
      for (const entry of entries) {
        const isTop = entry.skillArea === topMatches.skillset || entry.skillArea === topMatches.mindset;
        html += renderSkillMatrixRow(entry, blurred, isTop);
      }
      html += `</div></div>`;
    }

    skillMatrixContainer.innerHTML = html;
  }

  function renderSkillMatrixRow(entry: SkillMatrixEntry, blurred: boolean, isTopMatch: boolean): string {
    const isPrimary = entry.relevance === 'primary';
    const relevanceClass = isPrimary ? 'border-l-2 border-text-accent bg-bg-card/50' : '';
    const topMatchNote = isTopMatch ? ' (detailed above)' : '';

    const relevanceLabel = entry.relevance.charAt(0).toUpperCase() + entry.relevance.slice(1);

    // Use qualitative evidence when blurred, full evidence when unblurred
    const evidenceText = blurred ? entry.evidenceQualitative : entry.evidence;

    return `
      <div class="p-4 ${relevanceClass} bg-bg-card rounded">
        <div class="flex justify-between items-baseline mb-2">
          <span class="text-base text-text-primary font-medium">${entry.skillArea}</span>
          <span class="text-sm text-text-secondary uppercase tracking-wider">${relevanceLabel}${topMatchNote}</span>
        </div>
        <div class="${blurred ? 'blur-md select-none pointer-events-none' : ''} transition-all duration-500" data-evidence-full="${escapeAttr(entry.evidence)}" data-evidence-qual="${escapeAttr(entry.evidenceQualitative)}">
          <p class="text-sm text-text-secondary mb-1">${entry.matchReason}</p>
          <p class="text-base text-text-secondary">${evidenceText}</p>
        </div>
      </div>
    `;
  }

  function renderCaseStudyCard(cs: CaseStudyMatch, blurred: boolean): string {
    return `
      <div class="p-8 bg-bg-card border-t-[3px] border-text-accent">
        <p class="text-sm text-text-secondary uppercase tracking-wider mb-2">${cs.company}</p>
        <h3 class="font-display text-xl text-text-primary mb-2">${cs.role}</h3>
        <p class="text-base text-text-secondary mb-4">${cs.descriptor}</p>
        <p class="text-sm text-text-accent mb-4">${cs.relevanceReason}</p>
        <div class="${blurred ? 'blur-md select-none pointer-events-none' : ''} transition-all duration-500">
          <div class="text-base text-text-secondary leading-relaxed whitespace-pre-line">${cs.fullContent}</div>
        </div>
      </div>
    `;
  }

  function escapeAttr(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function unblurSection(sectionId: string) {
    const section = document.getElementById(sectionId);
    if (!section) return;
    const blurredElements = section.querySelectorAll('.blur-md');
    blurredElements.forEach(el => {
      el.classList.remove('blur-md', 'select-none', 'pointer-events-none');
    });
    // Swap qualitative evidence to full evidence for skill matrix
    if (sectionId === 'skill-matrix-section') {
      swapEvidence(sectionId);
    }
  }

  function swapEvidence(sectionId: string) {
    const section = document.getElementById(sectionId);
    if (!section) return;
    const rows = section.querySelectorAll('[data-evidence-full]');
    rows.forEach(el => {
      const fullEvidence = el.getAttribute('data-evidence-full') ?? '';
      const paragraphs = el.querySelectorAll('p');
      if (paragraphs.length >= 2) {
        paragraphs[1].textContent = fullEvidence;
      }
    });
  }

  // --- Legacy rendering for old shared URLs ---

  function renderLegacyResults(
    matches: LegacyMatch[],
    roleTitle: string | null,
    summary: string,
    token: string,
    isShared: boolean,
  ) {
    currentToken = token;

    if (roleTitle) {
      resultRoleTitle.textContent = roleTitle;
      resultRoleTitle.classList.remove('hidden');
    }
    resultSummary.textContent = summary;

    // Show all matches as visible cards
    matchesVisible.innerHTML = matches.map(m => renderLegacyMatchCard(m)).join('');

    // Hide new sections
    unlockGate.classList.add('hidden');
    skillMatrixSection.classList.add('hidden');
    caseStudiesSection.classList.add('hidden');

    showState('results');
  }

  function renderLegacyMatchCard(match: LegacyMatch): string {
    const categoryLabel = match.category === 'skillset' ? 'Skillset' : 'Mindset';
    const confidenceClass = match.confidence === 'high'
      ? 'bg-text-accent text-white'
      : match.confidence === 'medium'
        ? 'bg-bg-dark text-white'
        : 'bg-border-light text-text-primary';

    return `
      <div class="p-8 bg-bg-card border-t-[3px] border-text-accent">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-text-secondary uppercase tracking-wider">${match.aicdDomain}</span>
          <span class="text-xs font-medium px-3 py-1 rounded ${confidenceClass}">${match.confidence}</span>
        </div>
        <p class="text-xs text-text-accent uppercase tracking-wider font-medium mb-1">${categoryLabel} match</p>
        <h3 class="font-display text-xl text-text-primary mb-4">${match.skillArea}</h3>
        <p class="text-base text-text-secondary mb-4"><strong class="text-text-primary">Why this matches:</strong> ${match.matchReason}</p>
        <p class="text-base text-text-secondary"><strong class="text-text-primary">Evidence:</strong> ${match.evidence}</p>
      </div>
    `;
  }

  function showState(state: 'upload' | 'loading' | 'error' | 'results') {
    stateUpload.classList.toggle('hidden', state !== 'upload');
    stateLoading.classList.toggle('hidden', state !== 'loading');
    stateError.classList.toggle('hidden', state !== 'error');
    stateResults.classList.toggle('hidden', state !== 'results');
  }

  function showError(message: string) {
    errorMessage.textContent = message;
    showState('error');
  }
</script>
