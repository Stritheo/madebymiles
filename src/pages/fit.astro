---
import Base from '@/layouts/Base.astro';
---

<Base
  title="Fit Finder | Miles Sowden"
  description="Upload a role description and see how Miles Sowden's AICD skill matrix aligns to what the role requires."
>
  <section class="pt-48 pb-32 max-md:pt-32 max-md:pb-20">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h1 class="font-display text-[3.5rem] max-lg:text-5xl max-md:text-[2.5rem] leading-[1.1] tracking-[-0.02em] text-text-primary mb-6">
        Role Fit
      </h1>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mb-16 max-w-[720px]">
        Upload a role description or paste the text. The analysis matches requirements against an AICD-aligned skill matrix and twenty years of career evidence. Built the same way I approach any problem: structured data, clear framework, technology doing the heavy lifting.
      </p>

      <!-- State: Upload form -->
      <div id="state-upload">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <!-- File upload -->
          <div>
            <div
              id="drop-zone"
              class="flex flex-col items-center justify-center p-10 border-2 border-dashed border-border-light bg-bg-card rounded-lg cursor-pointer hover:border-text-accent transition-colors min-h-[200px]"
              role="region"
              aria-label="File upload area"
              tabindex="0"
            >
              <svg class="w-10 h-10 mb-4 text-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
              </svg>
              <p class="text-base text-text-secondary mb-1">Drop a PDF here or click to browse</p>
              <p id="file-name" class="text-sm text-text-accent font-medium hidden"></p>
              <input id="file-input" type="file" accept=".pdf,application/pdf" class="hidden" aria-label="Upload role description PDF" />
            </div>
          </div>

          <!-- Text paste -->
          <div>
            <textarea
              id="text-input"
              class="w-full min-h-[200px] p-6 border border-border-light bg-bg-card rounded-lg text-base text-text-primary resize-none focus:outline-none focus:border-text-accent transition-colors"
              placeholder="Or paste the role description here..."
              aria-label="Paste role description"
            ></textarea>
            <p id="char-hint" class="text-sm text-text-secondary mt-2 hidden">
              <span id="char-count">0</span>/100 characters minimum
            </p>
          </div>
        </div>

        <!-- Turnstile invisible widget -->
        <div id="turnstile-widget" class="mb-4"></div>

        <button
          id="analyse-btn"
          disabled
          class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-10 py-4.5 max-md:px-6 max-md:py-3 text-base bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26] hover:border-[#151A26] hover:-translate-y-px disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:translate-y-0 mb-6"
        >
          Analyse fit
        </button>

        <p class="text-sm text-text-secondary">
          Your document is sent encrypted to Anthropic's Claude API for analysis. It is not used to train models and is automatically deleted within 30 days.
          <a href="/privacy#fit-finder" class="text-text-accent hover:underline">Full privacy details</a>
        </p>
      </div>

      <!-- State: Loading (Phase 1) -->
      <div id="state-loading" class="hidden" aria-live="polite">
        <div class="flex flex-col items-center justify-center py-12">
          <p class="text-xl text-text-primary font-medium mb-2">Analysing role fit...</p>
          <p class="text-base text-text-secondary mb-6">This usually takes 10 to 15 seconds</p>
          <div class="w-full max-w-[400px] h-1.5 bg-border-light rounded-full overflow-hidden">
            <div id="progress-bar" class="h-full bg-text-accent rounded-full transition-all duration-500 ease-out" style="width: 0%"></div>
          </div>
          <p id="progress-percent" class="text-sm text-text-secondary mt-3">0%</p>
        </div>
        <!-- Skeleton preview of result cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
          <div class="p-10 max-md:p-8 bg-bg-card animate-pulse">
            <div class="h-4 bg-border-light rounded w-1/3 mb-4"></div>
            <div class="h-6 bg-border-light rounded w-3/4 mb-6"></div>
            <div class="space-y-2">
              <div class="h-3 bg-border-light rounded w-full"></div>
              <div class="h-3 bg-border-light rounded w-5/6"></div>
              <div class="h-3 bg-border-light rounded w-2/3"></div>
            </div>
          </div>
          <div class="p-10 max-md:p-8 bg-bg-card animate-pulse">
            <div class="h-4 bg-border-light rounded w-1/3 mb-4"></div>
            <div class="h-6 bg-border-light rounded w-3/4 mb-6"></div>
            <div class="space-y-2">
              <div class="h-3 bg-border-light rounded w-full"></div>
              <div class="h-3 bg-border-light rounded w-5/6"></div>
              <div class="h-3 bg-border-light rounded w-2/3"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- State: Error -->
      <div id="state-error" class="hidden">
        <div class="p-8 bg-bg-card border-t-[3px] border-red-500 mb-8">
          <p class="text-lg text-text-primary mb-2 font-medium">Something went wrong</p>
          <p id="error-message" class="text-base text-text-secondary mb-6"></p>
          <button
            id="retry-btn"
            class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-5 py-2.5 text-sm bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26]"
          >
            Try again
          </button>
        </div>
      </div>

      <!-- State: Results -->
      <div id="state-results" class="hidden">

        <!-- Phase 1: Executive Summary -->
        <div id="result-summary" class="p-8 bg-bg-card border-t-[3px] border-text-accent mb-8">
          <p id="result-role-title" class="text-sm text-text-secondary uppercase tracking-wider mb-2 hidden"></p>
          <p id="result-summary-text" class="text-lg text-text-primary leading-relaxed"></p>
        </div>

        <!-- Phase 1: Top match cards -->
        <div id="matches-visible" class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8"></div>

        <!-- Phase 1: Evaluation preview -->
        <div id="evaluation-preview" class="mb-8 p-6 bg-bg-card border border-border-light rounded-lg">
          <p id="preview-text" class="text-base text-text-secondary text-center"></p>
        </div>

        <!-- Unlock Gate -->
        <div id="unlock-gate" class="mb-12">
          <div class="flex flex-col items-center py-10 border border-border-light rounded-lg bg-bg-card">
            <p class="text-lg text-text-primary leading-relaxed mb-2 max-w-[560px] text-center">
              The full evaluation and matched case studies are shared in conversation. The depth is there. It belongs in a discussion, not on a screen.
            </p>
            <div id="unlock-buttons" class="flex flex-wrap gap-4 mt-6 justify-center max-md:flex-col max-md:w-full max-md:px-4">
              <button
                id="linkedin-unlock-btn"
                class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-8 py-3.5 max-md:px-4 max-md:py-3 text-base bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26] hover:border-[#151A26] hover:-translate-y-px"
              >
                Connect on LinkedIn
              </button>
              <a
                id="whatsapp-btn"
                href="https://wa.me/61414185721?text=I%20ran%20the%20Fit%20Finder%20and%20would%20welcome%20a%20conversation."
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-8 py-3.5 max-md:px-4 max-md:py-3 text-base bg-transparent text-text-primary border-[1.5px] border-border-light hover:border-[#D4D4D4] hover:bg-bg-card"
              >
                Open WhatsApp
              </a>
            </div>
            <!-- Post-connect section choices -->
            <div id="unlock-choice" class="hidden mt-6 w-full max-w-[560px]">
              <p class="text-base text-text-secondary mb-4 text-center">I've connected. Show me:</p>
              <div class="flex flex-wrap gap-4 justify-center max-md:flex-col max-md:w-full max-md:px-4">
                <button
                  id="show-matrix-btn"
                  class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-6 py-3 max-md:px-4 text-base bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26]"
                >
                  The full skill evaluation
                </button>
                <button
                  id="show-cases-btn"
                  class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-6 py-3 max-md:px-4 text-base bg-transparent text-text-primary border-[1.5px] border-border-light hover:border-[#D4D4D4] hover:bg-bg-card"
                >
                  The matched case studies
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Phase 2: Loading (inline, appears when unlocking) -->
        <div id="detail-loading" class="hidden mb-8" aria-live="polite">
          <div class="flex flex-col items-center justify-center py-12 bg-bg-card border border-border-light rounded-lg">
            <p id="detail-loading-title" class="text-lg text-text-primary font-medium mb-2">Building full evaluation...</p>
            <p id="detail-loading-subtitle" class="text-base text-text-secondary mb-6">This takes 30 to 45 seconds. The depth is worth the wait.</p>
            <div class="w-full max-w-[400px] h-1.5 bg-border-light rounded-full overflow-hidden mx-6">
              <div id="detail-progress-bar" class="h-full bg-text-accent rounded-full transition-all duration-500 ease-out" style="width: 0%"></div>
            </div>
            <p id="detail-progress-percent" class="text-sm text-text-secondary mt-3">0%</p>
          </div>
          <!-- Skeleton preview of skill matrix rows -->
          <div class="space-y-4 mt-6">
            <div class="p-6 bg-bg-card animate-pulse flex items-center gap-4">
              <div class="h-5 bg-border-light rounded w-1/4"></div>
              <div class="h-4 bg-border-light rounded w-16"></div>
              <div class="flex-1 h-3 bg-border-light rounded"></div>
            </div>
            <div class="p-6 bg-bg-card animate-pulse flex items-center gap-4">
              <div class="h-5 bg-border-light rounded w-1/3"></div>
              <div class="h-4 bg-border-light rounded w-16"></div>
              <div class="flex-1 h-3 bg-border-light rounded"></div>
            </div>
            <div class="p-6 bg-bg-card animate-pulse flex items-center gap-4">
              <div class="h-5 bg-border-light rounded w-1/4"></div>
              <div class="h-4 bg-border-light rounded w-16"></div>
              <div class="flex-1 h-3 bg-border-light rounded"></div>
            </div>
            <div class="p-6 bg-bg-card animate-pulse flex items-center gap-4">
              <div class="h-5 bg-border-light rounded w-2/5"></div>
              <div class="h-4 bg-border-light rounded w-16"></div>
              <div class="flex-1 h-3 bg-border-light rounded"></div>
            </div>
          </div>
        </div>

        <!-- Phase 2: AICD Skill Matrix -->
        <div id="skill-matrix-section" class="hidden mb-12">
          <h2 class="font-display text-3xl text-text-primary mb-2">AICD Skill Matrix Evaluation</h2>
          <p class="text-base text-text-secondary mb-8">All 13 skill areas evaluated against the role requirements across four AICD governance domains.</p>
          <div id="skill-matrix" class="space-y-10"></div>
        </div>

        <!-- Phase 2: Matched Case Studies -->
        <div id="case-studies-section" class="hidden mb-12">
          <h2 class="font-display text-3xl text-text-primary mb-2">Matched Case Studies</h2>
          <p class="text-base text-text-secondary mb-8">Career evidence matched to the role requirements.</p>
          <div id="case-studies" class="space-y-6"></div>
        </div>

        <!-- Also-available buttons (after one section unlocked) -->
        <div id="also-available" class="hidden mb-8 flex justify-center">
          <button
            id="also-btn"
            class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-6 py-3 text-base bg-transparent text-text-accent border-[1.5px] border-text-accent hover:bg-text-accent hover:text-white"
          >
          </button>
        </div>

        <!-- Post-unlock footer -->
        <div id="results-footer" class="flex flex-col items-center py-8 mb-8">
          <p class="text-lg text-text-primary mb-6">Good outcomes start with good conversations.</p>
          <div class="flex flex-wrap gap-4">
            <a
              href="https://www.linkedin.com/in/milessowden"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-8 py-3.5 text-base bg-bg-dark text-white border-[1.5px] border-bg-dark hover:bg-[#151A26] hover:border-[#151A26] hover:-translate-y-px"
            >
              Connect on LinkedIn
            </a>
            <a
              href="https://wa.me/61414185721?text=Hi%20Miles%2C%20I%20used%20Fit%20Finder%20and%20would%20like%20to%20connect."
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center font-medium no-underline rounded-lg transition-all duration-250 px-8 py-3.5 text-base bg-transparent text-text-primary border-[1.5px] border-border-light hover:border-[#D4D4D4] hover:bg-bg-card"
            >
              Open WhatsApp
            </a>
          </div>
          <button
            id="analyse-another-btn"
            class="mt-8 text-base text-text-secondary hover:text-text-primary transition-colors underline underline-offset-4"
          >
            Analyse another role
          </button>
        </div>

      </div>
    </div>
  </section>

  <!-- Sentry error tracking -->
  <script is:inline src="https://browser.sentry-cdn.com/8.49.0/bundle.min.js" crossorigin="anonymous"></script>
  <script is:inline>
    if (window.Sentry) {
      Sentry.init({
        dsn: "https://ddf1759d25a21068958638d61044b374@o4510983886209024.ingest.us.sentry.io/4510983955808256",
        tracesSampleRate: 0.1,
        environment: "production",
        ignoreErrors: [
          "ResizeObserver loop",
          "Non-Error promise rejection",
          "Network request failed"
        ]
      });
    }
  </script>

  <!-- Turnstile script loaded explicitly outside Astro's bundled scripts -->
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
</Base>

<script>
  const API_BASE = '/api/fit';
  const TURNSTILE_SITE_KEY = '0x4AAAAAACpeOHmo95tCwiiA';

  // --- Turnstile ---

  let turnstileToken: string | null = null;
  let turnstileWidgetId: string | null = null;

  function renderTurnstileWidget() {
    if (turnstileWidgetId !== null) return; // Already rendered
    const ts = (window as any).turnstile;
    if (!ts) return;
    turnstileWidgetId = ts.render('#turnstile-widget', {
      sitekey: TURNSTILE_SITE_KEY,
      callback: (token: string) => { turnstileToken = token; },
      'expired-callback': () => { turnstileToken = null; },
      'error-callback': () => { turnstileToken = null; },
      theme: 'light',
      size: 'flexible',
    });
  }

  function resetTurnstile() {
    turnstileToken = null;
    if (turnstileWidgetId !== null && typeof (window as any).turnstile !== 'undefined') {
      (window as any).turnstile.reset(turnstileWidgetId);
    }
  }

  // Poll for Turnstile API readiness (loaded via HTML script tag)
  // Interval is cleared once Turnstile loads, or after 30s to prevent leaks
  let tsReadyAttempts = 0;
  const tsReadyCheck = setInterval(() => {
    tsReadyAttempts++;
    if (typeof (window as any).turnstile !== 'undefined') {
      clearInterval(tsReadyCheck);
      renderTurnstileWidget();
    } else if (tsReadyAttempts > 300) {
      clearInterval(tsReadyCheck);
    }
  }, 100);

  // --- Element references ---

  const stateUpload = document.getElementById('state-upload')!;
  const stateLoading = document.getElementById('state-loading')!;
  const stateError = document.getElementById('state-error')!;
  const stateResults = document.getElementById('state-results')!;
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const fileName = document.getElementById('file-name')!;
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const analyseBtn = document.getElementById('analyse-btn') as HTMLButtonElement;
  const errorMessage = document.getElementById('error-message')!;
  const retryBtn = document.getElementById('retry-btn')!;
  const resultRoleTitle = document.getElementById('result-role-title')!;
  const resultSummary = document.getElementById('result-summary-text')!;
  const matchesVisible = document.getElementById('matches-visible')!;
  const evaluationPreview = document.getElementById('evaluation-preview')!;
  const previewText = document.getElementById('preview-text')!;
  const unlockGate = document.getElementById('unlock-gate')!;
  const unlockButtons = document.getElementById('unlock-buttons')!;
  const unlockChoice = document.getElementById('unlock-choice')!;
  const linkedinUnlockBtn = document.getElementById('linkedin-unlock-btn')!;
  const showMatrixBtn = document.getElementById('show-matrix-btn')!;
  const showCasesBtn = document.getElementById('show-cases-btn')!;
  const detailLoading = document.getElementById('detail-loading')!;
  const detailLoadingTitle = document.getElementById('detail-loading-title')!;
  const skillMatrixSection = document.getElementById('skill-matrix-section')!;
  const skillMatrixContainer = document.getElementById('skill-matrix')!;
  const caseStudiesSection = document.getElementById('case-studies-section')!;
  const caseStudiesContainer = document.getElementById('case-studies')!;
  const alsoAvailable = document.getElementById('also-available')!;
  const alsoBtn = document.getElementById('also-btn')!;
  const charHint = document.getElementById('char-hint')!;
  const charCount = document.getElementById('char-count')!;
  const progressBar = document.getElementById('progress-bar')!;
  const progressPercent = document.getElementById('progress-percent')!;
  const detailProgressBar = document.getElementById('detail-progress-bar')!;
  const detailProgressPercent = document.getElementById('detail-progress-percent')!;

  // --- State ---

  let selectedFile: File | null = null;
  let currentToken: string | null = null;
  let currentSessionId: string | null = null;
  let detailData: DetailData | null = null;
  let detailLoaded = false;
  let progressInterval: ReturnType<typeof setInterval> | null = null;
  let detailProgressInterval: ReturnType<typeof setInterval> | null = null;
  let firstUnlockedSection: 'matrix' | 'cases' | null = null;
  let detailFetchError: string | null = null;

  // --- Interfaces ---

  interface HydratedTopMatch {
    skillArea: string;
    aicdDomain: string;
    matchReason: string;
    evidenceQualitative: string;
    evidence: string;
    headline: string;
    confidence: 'high' | 'medium' | 'low';
  }

  interface SummaryData {
    roleTitle: string | null;
    summary: string;
    topMatches: {
      skillset: HydratedTopMatch;
      mindset: HydratedTopMatch;
    };
    sessionId: string;
  }

  interface SkillMatrixEntry {
    aicdDomain: string;
    skillArea: string;
    relevance: 'primary' | 'supporting' | 'noted';
    matchReason: string;
    evidence: string;
    evidenceQualitative: string;
    headline: string;
    confidence: 'high' | 'medium' | 'low';
  }

  interface CaseStudyMatch {
    company: string;
    role: string;
    descriptor: string;
    relevanceReason: string;
    fullContent: string;
  }

  interface DetailData {
    skillMatrix: SkillMatrixEntry[];
    relevantCaseStudies: CaseStudyMatch[];
    token: string;
    analysedAt: string;
  }

  // Legacy format for old shared URLs
  interface LegacyMatch {
    rank: number;
    category: 'skillset' | 'mindset';
    aicdDomain: string;
    skillArea: string;
    matchReason: string;
    evidence: string;
    confidence: 'high' | 'medium' | 'low';
  }

  // --- Progress bar helpers ---

  function startProgress(target: 'phase1' | 'phase2' = 'phase1') {
    const bar = target === 'phase1' ? progressBar : detailProgressBar;
    const pct = target === 'phase1' ? progressPercent : detailProgressPercent;
    // Phase 2 starts faster because data may already be loading in background
    const rate = target === 'phase1' ? 0.06 : 0.05;
    let progress = target === 'phase2' ? 30 : 0; // Phase 2 starts at 30% (pre-fetch head start)
    bar.style.width = `${progress}%`;
    pct.textContent = `${Math.round(progress)}%`;
    const interval = setInterval(() => {
      progress += (90 - progress) * rate;
      const rounded = Math.min(Math.round(progress), 90);
      bar.style.width = `${rounded}%`;
      pct.textContent = `${rounded}%`;
    }, 200);
    if (target === 'phase1') progressInterval = interval;
    else detailProgressInterval = interval;
  }

  function finishProgress(target: 'phase1' | 'phase2' = 'phase1') {
    const interval = target === 'phase1' ? progressInterval : detailProgressInterval;
    const bar = target === 'phase1' ? progressBar : detailProgressBar;
    const pct = target === 'phase1' ? progressPercent : detailProgressPercent;
    if (interval) clearInterval(interval);
    bar.style.width = '100%';
    pct.textContent = '100%';
  }

  // --- Check for shared URL token ---

  const urlToken = new URLSearchParams(window.location.search).get('token');
  if (urlToken) {
    loadSharedResult(urlToken);
  }

  // --- Event listeners ---

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-text-accent', 'bg-bg-primary');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-text-accent', 'bg-bg-primary');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-text-accent', 'bg-bg-primary');
    const file = e.dataTransfer?.files[0];
    if (file) handleFileSelect(file);
  });

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      fileInput.click();
    }
  });

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) handleFileSelect(file);
  });

  textInput.addEventListener('input', updateButtonState);
  analyseBtn.addEventListener('click', analyse);
  retryBtn.addEventListener('click', () => showState('upload'));

  // Unlock flow
  linkedinUnlockBtn.addEventListener('click', () => {
    window.open('https://www.linkedin.com/messaging/compose/?recipient=milessowden', '_blank');
    unlockButtons.classList.add('hidden');
    unlockChoice.classList.remove('hidden');
  });

  document.getElementById('whatsapp-btn')!.addEventListener('click', () => {
    setTimeout(() => {
      unlockButtons.classList.add('hidden');
      unlockChoice.classList.remove('hidden');
    }, 500);
  });

  showMatrixBtn.addEventListener('click', () => unlockSection('matrix'));
  showCasesBtn.addEventListener('click', () => unlockSection('cases'));

  alsoBtn.addEventListener('click', () => {
    if (!detailData) return;
    const otherSection = firstUnlockedSection === 'matrix' ? 'cases' : 'matrix';
    revealSection(otherSection);
    alsoAvailable.classList.add('hidden');
  });

  document.getElementById('analyse-another-btn')!.addEventListener('click', resetToUpload);


  // --- Core functions ---

  function resetToUpload() {
    // Clear all state
    selectedFile = null;
    currentToken = null;
    currentSessionId = null;
    detailData = null;
    detailLoaded = false;
    detailPromise = null;
    firstUnlockedSection = null;
    detailFetchError = null;

    // Clear UI
    textInput.value = '';
    fileName.textContent = '';
    fileName.classList.add('hidden');
    fileInput.value = '';
    charHint.classList.add('hidden');
    analyseBtn.disabled = true;
    resultRoleTitle.classList.add('hidden');
    matchesVisible.innerHTML = '';
    skillMatrixContainer.innerHTML = '';
    caseStudiesContainer.innerHTML = '';
    unlockButtons.classList.remove('hidden');
    unlockChoice.classList.add('hidden');

    // Remove token from URL without reload
    const cleanUrl = window.location.pathname;
    window.history.replaceState({}, '', cleanUrl);

    // Reset Turnstile for next analysis
    resetTurnstile();
    renderTurnstileWidget();

    showState('upload');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function handleFileSelect(file: File) {
    if (file.type !== 'application/pdf' && !file.name.endsWith('.pdf')) {
      showError('Only PDF files are accepted');
      return;
    }
    if (file.size > 5 * 1024 * 1024) {
      showError('File is too large (max 5MB)');
      return;
    }
    selectedFile = file;
    fileName.textContent = file.name;
    fileName.classList.remove('hidden');
    textInput.value = '';
    updateButtonState();
  }

  function updateButtonState() {
    const hasFile = selectedFile !== null;
    const trimmedLength = textInput.value.trim().length;
    const hasText = trimmedLength >= 100;
    analyseBtn.disabled = !hasFile && !hasText;
    if (trimmedLength > 0 && trimmedLength < 100 && !hasFile) {
      charCount.textContent = String(trimmedLength);
      charHint.classList.remove('hidden');
    } else {
      charHint.classList.add('hidden');
    }
    if (trimmedLength > 0) {
      selectedFile = null;
      fileName.classList.add('hidden');
    }
  }

  async function waitForTurnstile(maxWaitMs = 10000): Promise<string | null> {
    if (turnstileToken) return turnstileToken;
    const start = Date.now();
    return new Promise((resolve) => {
      const check = () => {
        if (turnstileToken) return resolve(turnstileToken);
        if (Date.now() - start > maxWaitMs) return resolve(null);
        setTimeout(check, 250);
      };
      check();
    });
  }

  async function analyse() {
    showState('loading');
    startProgress('phase1');

    const tsToken = await waitForTurnstile();
    if (!tsToken) {
      finishProgress('phase1');
      showError('Security verification timed out. Please refresh the page and try again.');
      return;
    }

    // Reset Turnstile AFTER we have the token safely captured
    resetTurnstile();

    try {
      let response: Response;

      if (selectedFile) {
        const formData = new FormData();
        formData.append('file', selectedFile);
        // Do NOT set Content-Type manually for FormData — browser must set
        // the multipart boundary automatically. Only append the custom header.
        response = await fetch(API_BASE, {
          method: 'POST',
          headers: { 'X-Turnstile-Token': tsToken },
          body: formData,
          signal: AbortSignal.timeout(60_000),
        });
      } else {
        response = await fetch(API_BASE, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Turnstile-Token': tsToken,
          },
          body: JSON.stringify({ text: textInput.value.trim() }),
          signal: AbortSignal.timeout(60_000),
        });
      }

      if (!response.ok) {
        const err = await response.json() as { error?: string; limitType?: string };
        if (err.limitType === 'global') {
          showGlobalLimitError();
          finishProgress('phase1');
          return;
        }
        throw new Error(err.error ?? `Request failed (${response.status})`);
      }

      const data = await response.json() as SummaryData;
      finishProgress('phase1');
      renderSummary(data);
    } catch (err) {
      finishProgress('phase1');
      showError(err instanceof Error ? err.message : 'Analysis failed. Please try again.');
    }
  }

  function renderSummary(data: SummaryData) {
    currentSessionId = data.sessionId;

    // Summary
    if (data.roleTitle) {
      resultRoleTitle.textContent = data.roleTitle;
      resultRoleTitle.classList.remove('hidden');
    }
    resultSummary.textContent = data.summary;

    // Top match cards
    matchesVisible.innerHTML = [
      renderTopMatchCard(data.topMatches.skillset, 'Skillset'),
      renderTopMatchCard(data.topMatches.mindset, 'Mindset'),
    ].join('');

    // Preview text
    previewText.textContent = '13 skill areas evaluated across 4 AICD governance domains. Unlock the full evaluation below.';
    evaluationPreview.classList.remove('hidden');

    // Show gate, hide detail sections
    unlockGate.classList.remove('hidden');
    skillMatrixSection.classList.add('hidden');
    caseStudiesSection.classList.add('hidden');
    detailLoading.classList.add('hidden');
    alsoAvailable.classList.add('hidden');

    // Reset state
    detailData = null;
    detailLoaded = false;
    currentToken = null;
    firstUnlockedSection = null;
    detailFetchError = null;

    showState('results');

    // Pre-fetch Phase 2 in background so it is ready when the user unlocks
    prefetchDetail();
  }

  // Background pre-fetch promise — resolved when Phase 2 data arrives
  let detailPromise: Promise<DetailData | null> | null = null;

  function prefetchDetail() {
    if (!currentSessionId || detailLoaded) return;
    detailPromise = fetchDetailData(currentSessionId);
  }

  async function fetchDetailData(sessionId: string): Promise<DetailData | null> {
    try {
      const response = await fetch(`${API_BASE}/detail`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId }),
        signal: AbortSignal.timeout(150_000),
      });

      if (!response.ok) {
        const err = await response.json() as { error?: string };
        throw new Error(err.error ?? `Detail request failed (${response.status})`);
      }

      return await response.json() as DetailData;
    } catch (err) {
      console.error('Detail fetch failed:', err);
      detailFetchError = err instanceof Error ? err.message : 'Could not load full evaluation.';
      return null;
    }
  }

  async function loadDetail(): Promise<boolean> {
    if (detailLoaded && detailData) return true;
    if (!currentSessionId) return false;

    // Reset error state
    detailFetchError = null;

    // Use pre-fetched promise if available, otherwise start a new fetch
    const promise = detailPromise ?? fetchDetailData(currentSessionId);
    detailPromise = null;

    const result = await promise;
    if (!result) {
      showDetailError(detailFetchError ?? 'Could not load full evaluation. Please try again.');
      return false;
    }

    detailData = result;
    currentToken = result.token;
    detailLoaded = true;
    return true;
  }

  async function unlockSection(section: 'matrix' | 'cases') {
    // Hide gate, show loading
    unlockGate.classList.add('hidden');
    evaluationPreview.classList.add('hidden');
    detailLoading.classList.remove('hidden');
    detailLoadingTitle.textContent = section === 'matrix'
      ? 'Building full skill evaluation...'
      : 'Loading matched case studies...';
    const subtitle = document.getElementById('detail-loading-subtitle')!;
    subtitle.textContent = detailLoaded
      ? 'Almost there...'
      : 'This takes 30 to 45 seconds. The depth is worth the wait.';
    startProgress('phase2');

    const success = await loadDetail();
    finishProgress('phase2');

    if (!success || !detailData) {
      detailLoading.classList.add('hidden');
      return;
    }

    // Hide loading
    setTimeout(() => {
      detailLoading.classList.add('hidden');

      // Render both sections (data is ready)
      renderSkillMatrix(detailData!.skillMatrix);
      renderCaseStudies(detailData!.relevantCaseStudies);

      // Show the requested section
      firstUnlockedSection = section;
      revealSection(section);

      // Show "also available" button for the other section
      const otherLabel = section === 'matrix' ? 'Also show: matched case studies' : 'Also show: full skill evaluation';
      alsoBtn.textContent = otherLabel;
      alsoAvailable.classList.remove('hidden');

      // Enable sharing
  
    }, 300);
  }

  function revealSection(section: 'matrix' | 'cases') {
    if (section === 'matrix') {
      skillMatrixSection.classList.remove('hidden');
      skillMatrixSection.scrollIntoView({ behavior: 'smooth' });
    } else {
      caseStudiesSection.classList.remove('hidden');
      caseStudiesSection.scrollIntoView({ behavior: 'smooth' });
    }
  }

  function showDetailError(message: string) {
    detailLoading.classList.add('hidden');
    // Re-show the gate with the choice buttons and a retry option
    unlockGate.classList.remove('hidden');
    unlockButtons.classList.add('hidden');
    unlockChoice.classList.remove('hidden');

    // Remove any previous error messages
    const oldErr = unlockChoice.querySelector('.detail-error-msg');
    if (oldErr) oldErr.remove();

    // Show error with retry button
    const errDiv = document.createElement('div');
    errDiv.className = 'detail-error-msg mt-4 text-center';
    errDiv.innerHTML = `<p class="text-sm text-red-500 mb-3">${esc(message)}</p>
      <button class="text-sm text-text-accent underline hover:text-[#B36F4F]" id="detail-retry-btn">Try again</button>`;
    unlockChoice.appendChild(errDiv);

    // Reset prefetch state so retry triggers a fresh fetch
    detailPromise = null;
    detailFetchError = null;

    document.getElementById('detail-retry-btn')?.addEventListener('click', () => {
      errDiv.remove();
      // Re-trigger the last section the user tried to unlock
      const section = firstUnlockedSection ?? 'matrix';
      unlockSection(section);
    });
  }

  // --- Shared URL loading ---

  async function loadSharedResult(token: string) {
    showState('loading');
    startProgress('phase1');

    try {
      const response = await fetch(`${API_BASE}/verify?token=${encodeURIComponent(token)}`);
      if (!response.ok) {
        throw new Error('This result link has expired or is invalid.');
      }

      const data = await response.json();
      finishProgress('phase1');
      currentToken = token;

      // Handle new combined format (has topMatches as objects)
      if (data.skillMatrix && data.topMatches?.skillset?.skillArea) {
        renderSharedResult(data);
      }
      // Handle legacy format (topMatches as strings or matches array)
      else if ('matches' in data) {
        renderLegacyResults(data.matches, data.roleTitle, data.summary, token);
      }
      // Handle old format where topMatches are strings
      else if (data.skillMatrix) {
        renderOldSharedResult(data, token);
      }
    } catch (err) {
      finishProgress('phase1');
      showError(err instanceof Error ? err.message : 'Could not load shared result.');
    }
  }

  function renderSharedResult(data: {
    roleTitle: string | null;
    summary: string;
    topMatches: { skillset: HydratedTopMatch; mindset: HydratedTopMatch };
    skillMatrix: SkillMatrixEntry[];
    relevantCaseStudies: CaseStudyMatch[];
  }) {
    // Summary
    if (data.roleTitle) {
      resultRoleTitle.textContent = data.roleTitle;
      resultRoleTitle.classList.remove('hidden');
    }
    resultSummary.textContent = data.summary;

    // Top match cards
    matchesVisible.innerHTML = [
      renderTopMatchCard(data.topMatches.skillset, 'Skillset'),
      renderTopMatchCard(data.topMatches.mindset, 'Mindset'),
    ].join('');

    // Full sections (no gate for shared view)
    renderSkillMatrix(data.skillMatrix);
    renderCaseStudies(data.relevantCaseStudies);

    evaluationPreview.classList.add('hidden');
    unlockGate.classList.add('hidden');
    detailLoading.classList.add('hidden');
    skillMatrixSection.classList.remove('hidden');
    caseStudiesSection.classList.remove('hidden');
    alsoAvailable.classList.add('hidden');


    showState('results');
  }

  // Handle old shared format where topMatches were string skill names
  function renderOldSharedResult(data: {
    roleTitle: string | null;
    summary: string;
    topMatches: { skillset: string; mindset: string };
    skillMatrix: SkillMatrixEntry[];
    relevantCaseStudies: CaseStudyMatch[];
  }, token: string) {
    if (data.roleTitle) {
      resultRoleTitle.textContent = data.roleTitle;
      resultRoleTitle.classList.remove('hidden');
    }
    resultSummary.textContent = data.summary;

    // Find top match entries from matrix
    const topSkillset = data.skillMatrix.find(e => e.skillArea === data.topMatches.skillset);
    const topMindset = data.skillMatrix.find(e => e.skillArea === data.topMatches.mindset);

    if (topSkillset && topMindset) {
      matchesVisible.innerHTML = [
        renderTopMatchCardFromEntry(topSkillset, 'Skillset'),
        renderTopMatchCardFromEntry(topMindset, 'Mindset'),
      ].join('');
    }

    renderSkillMatrix(data.skillMatrix);
    renderCaseStudies(data.relevantCaseStudies);

    evaluationPreview.classList.add('hidden');
    unlockGate.classList.add('hidden');
    detailLoading.classList.add('hidden');
    skillMatrixSection.classList.remove('hidden');
    caseStudiesSection.classList.remove('hidden');
    alsoAvailable.classList.add('hidden');


    showState('results');
  }

  // --- Rendering functions ---

  function renderTopMatchCard(entry: HydratedTopMatch, categoryLabel: string): string {
    return `
      <div class="p-8 bg-bg-card border-t-[3px] border-text-accent">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-text-secondary uppercase tracking-wider">${esc(entry.aicdDomain)}</span>
          <span class="text-xs font-medium px-3 py-1 rounded ${confidenceClass(entry.confidence)}">${esc(entry.confidence)}</span>
        </div>
        <p class="text-xs text-text-accent uppercase tracking-wider font-medium mb-1">${esc(categoryLabel)} match</p>
        <h3 class="font-display text-xl text-text-primary mb-4">${esc(entry.skillArea)}</h3>
        <div class="mb-4">
          <p class="text-sm font-medium text-text-primary mb-1">Why this matches</p>
          <p class="text-base text-text-secondary">${esc(entry.matchReason)}</p>
        </div>
        <div>
          <p class="text-sm font-medium text-text-primary mb-1">Evidence</p>
          <p class="text-base text-text-secondary">${esc(entry.evidenceQualitative)}</p>
        </div>
      </div>
    `;
  }

  function renderTopMatchCardFromEntry(entry: SkillMatrixEntry, categoryLabel: string): string {
    return `
      <div class="p-8 bg-bg-card border-t-[3px] border-text-accent">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-text-secondary uppercase tracking-wider">${esc(entry.aicdDomain)}</span>
          <span class="text-xs font-medium px-3 py-1 rounded ${confidenceClass(entry.confidence)}">${esc(entry.confidence)}</span>
        </div>
        <p class="text-xs text-text-accent uppercase tracking-wider font-medium mb-1">${esc(categoryLabel)} match</p>
        <h3 class="font-display text-xl text-text-primary mb-4">${esc(entry.skillArea)}</h3>
        <div class="mb-4">
          <p class="text-sm font-medium text-text-primary mb-1">Why this matches</p>
          <p class="text-base text-text-secondary">${esc(entry.matchReason)}</p>
        </div>
        <div>
          <p class="text-sm font-medium text-text-primary mb-1">Evidence</p>
          <p class="text-base text-text-secondary">${esc(entry.evidenceQualitative)}</p>
        </div>
      </div>
    `;
  }

  function renderSkillMatrix(matrix: SkillMatrixEntry[]) {
    // Group by domain
    const domains = new Map<string, SkillMatrixEntry[]>();
    for (const entry of matrix) {
      const list = domains.get(entry.aicdDomain) ?? [];
      list.push(entry);
      domains.set(entry.aicdDomain, list);
    }

    let html = '';
    for (const [domain, entries] of domains) {
      const primaryCount = entries.filter(e => e.relevance === 'primary').length;
      const supportingCount = entries.filter(e => e.relevance === 'supporting').length;

      html += `<div class="mb-4">`;
      html += `<div class="mb-6">`;
      html += `<h3 class="font-display text-2xl text-text-primary mb-1">${esc(domain)}</h3>`;
      html += `<p class="text-sm text-text-secondary">${primaryCount} primary, ${supportingCount} supporting, ${entries.length - primaryCount - supportingCount} noted</p>`;
      html += `</div>`;
      html += `<div class="grid grid-cols-1 gap-8">`;
      for (const entry of entries) {
        html += renderSkillMatrixRow(entry);
      }
      html += `</div></div>`;
    }

    skillMatrixContainer.innerHTML = html;
  }

  function renderSkillMatrixRow(entry: SkillMatrixEntry): string {
    const isPrimary = entry.relevance === 'primary';
    const isSupporting = entry.relevance === 'supporting';
    const borderColor = isPrimary
      ? 'border-text-accent'
      : isSupporting
        ? 'border-bg-dark'
        : 'border-border-light';

    const relevanceLabel = entry.relevance.toUpperCase();

    return `
      <div class="p-8 max-md:p-6 bg-bg-card border-t-[3px] ${borderColor}">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-text-secondary uppercase tracking-wider">${esc(entry.aicdDomain)}</span>
          <div class="flex items-center gap-3">
            <span class="text-xs font-medium px-3 py-1 rounded ${confidenceClass(entry.confidence)}">${esc(entry.confidence)}</span>
            <span class="text-xs text-text-secondary uppercase tracking-wider">${esc(relevanceLabel)}</span>
          </div>
        </div>
        <h4 class="font-display text-xl text-text-primary mb-4">${esc(entry.skillArea)}</h4>
        <div class="mb-4">
          <p class="text-sm font-medium text-text-primary mb-1">Why this matches</p>
          <p class="text-base text-text-secondary leading-relaxed">${esc(entry.matchReason)}</p>
        </div>
        <div>
          <p class="text-sm font-medium text-text-primary mb-1">Evidence</p>
          <p class="text-base text-text-secondary leading-relaxed">${esc(entry.evidenceQualitative)}</p>
        </div>
      </div>
    `;
  }

  function renderCaseStudies(caseStudies: CaseStudyMatch[]) {
    caseStudiesContainer.innerHTML = caseStudies
      .map(cs => renderCaseStudyCard(cs))
      .join('');
  }

  function renderCaseStudyCard(cs: CaseStudyMatch): string {
    return `
      <div class="p-8 max-md:p-6 bg-bg-card border-t-[3px] border-text-accent">
        <p class="text-sm text-text-secondary uppercase tracking-wider mb-2">${esc(cs.company)}</p>
        <h3 class="font-display text-xl text-text-primary mb-2">${esc(cs.role)}</h3>
        <p class="text-base text-text-secondary mb-4">${esc(cs.descriptor)}</p>
        <div class="mb-4">
          <p class="text-sm font-medium text-text-accent mb-1">Relevance to this role</p>
          <p class="text-base text-text-secondary">${esc(cs.relevanceReason)}</p>
        </div>
        <div class="text-base text-text-secondary leading-relaxed whitespace-pre-line">${esc(cs.fullContent)}</div>
      </div>
    `;
  }

  // --- Legacy rendering for old shared URLs ---

  function renderLegacyResults(
    matches: LegacyMatch[],
    roleTitle: string | null,
    summary: string,
    token: string,
  ) {
    currentToken = token;

    if (roleTitle) {
      resultRoleTitle.textContent = roleTitle;
      resultRoleTitle.classList.remove('hidden');
    }
    resultSummary.textContent = summary;

    matchesVisible.innerHTML = matches.map(m => renderLegacyMatchCard(m)).join('');

    evaluationPreview.classList.add('hidden');
    unlockGate.classList.add('hidden');
    skillMatrixSection.classList.add('hidden');
    caseStudiesSection.classList.add('hidden');
    detailLoading.classList.add('hidden');
    alsoAvailable.classList.add('hidden');


    showState('results');
  }

  function renderLegacyMatchCard(match: LegacyMatch): string {
    const categoryLabel = match.category === 'skillset' ? 'Skillset' : 'Mindset';
    return `
      <div class="p-8 bg-bg-card border-t-[3px] border-text-accent">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm text-text-secondary uppercase tracking-wider">${esc(match.aicdDomain)}</span>
          <span class="text-xs font-medium px-3 py-1 rounded ${confidenceClass(match.confidence)}">${esc(match.confidence)}</span>
        </div>
        <p class="text-xs text-text-accent uppercase tracking-wider font-medium mb-1">${esc(categoryLabel)} match</p>
        <h3 class="font-display text-xl text-text-primary mb-4">${esc(match.skillArea)}</h3>
        <div class="mb-4">
          <p class="text-sm font-medium text-text-primary mb-1">Why this matches</p>
          <p class="text-base text-text-secondary">${esc(match.matchReason)}</p>
        </div>
        <div>
          <p class="text-sm font-medium text-text-primary mb-1">Evidence</p>
          <p class="text-base text-text-secondary">${esc(match.evidence)}</p>
        </div>
      </div>
    `;
  }

  // --- Helpers ---

  function esc(str: string): string {
    const el = document.createElement('span');
    el.textContent = str;
    return el.innerHTML;
  }

  function confidenceClass(level: string): string {
    return level === 'high'
      ? 'bg-text-accent text-white'
      : level === 'medium'
        ? 'bg-bg-dark text-white'
        : 'bg-border-light text-text-primary';
  }

  function showState(state: 'upload' | 'loading' | 'error' | 'results') {
    stateUpload.classList.toggle('hidden', state !== 'upload');
    stateLoading.classList.toggle('hidden', state !== 'loading');
    stateError.classList.toggle('hidden', state !== 'error');
    stateResults.classList.toggle('hidden', state !== 'results');
  }

  function showError(message: string) {
    errorMessage.textContent = message;
    showState('error');
  }

  function showGlobalLimitError() {
    errorMessage.innerHTML = `Due to current interest the Fit Finder has reached its daily limit. Please connect with me directly on <a href="https://www.linkedin.com/in/milessowden" target="_blank" rel="noopener" class="underline text-text-accent hover:text-[#B36F4F]">LinkedIn</a> or <a href="https://wa.me/61414185721" target="_blank" rel="noopener" class="underline text-text-accent hover:text-[#B36F4F]">WhatsApp</a>, or try again tomorrow.`;
    showState('error');
  }
</script>
