---
import Base from '@/layouts/Base.astro';
import CTA from '@/components/CTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  const sorted = entries.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((entry, i) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: {
      entry,
      prev: i > 0 ? sorted[i - 1] : null,
      next: i < sorted.length - 1 ? sorted[i + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id.replace(/\.md$/, '');
const canonicalURL = `https://milessowden.au/work/${slug}`;
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.summary,
  "author": {
    "@type": "Person",
    "name": "Miles Sowden",
    "url": "https://milessowden.au"
  },
  "publisher": {
    "@type": "Person",
    "name": "Miles Sowden"
  },
  "url": canonicalURL,
  "mainEntityOfPage": canonicalURL
};
---

<Base
  title={`${entry.data.company} | Miles Sowden`}
  description={entry.data.summary}
>
  <article class="pt-48 pb-32 max-md:pt-32 max-md:pb-20">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <a href="/experience" class="text-sm text-text-secondary hover:text-text-primary transition-colors no-underline mb-8 inline-block">&larr; Back to Experience</a>

      <h1 class="font-display text-[3.5rem] max-lg:text-5xl max-md:text-[2.5rem] leading-[1.1] tracking-[-0.02em] text-text-primary mb-4">
        {entry.data.company}
      </h1>
      <p class="text-xl text-text-secondary/70 mb-4">{entry.data.role}</p>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mb-16">
        {entry.data.summary}
      </p>

      <div class="prose prose-lg max-w-none
        prose-headings:font-display prose-headings:text-text-primary prose-headings:tracking-[-0.02em]
        prose-h2:text-2xl prose-h2:mt-16 prose-h2:mb-6 prose-h2:border-b-[3px] prose-h2:border-text-accent prose-h2:pb-4 prose-h2:inline-block
        prose-h3:text-xl prose-h3:mt-10 prose-h3:mb-4
        prose-p:text-text-secondary prose-p:leading-relaxed
        prose-strong:text-text-primary prose-strong:font-semibold
        prose-li:text-text-secondary prose-li:leading-relaxed
        prose-ul:space-y-2
      ">
        <Content />
      </div>

      {(prev || next) && (
        <nav class="mt-16 pt-8 border-t border-border-light grid grid-cols-2 gap-8">
          {prev ? (
            <a href={`/work/${prev.id.replace(/\.md$/, '')}`} class="no-underline group">
              <p class="text-sm text-text-secondary/70 mb-1">&larr; Previous</p>
              <p class="text-base text-text-primary group-hover:text-text-accent transition-colors">{prev.data.company}</p>
            </a>
          ) : <div />}
          {next ? (
            <a href={`/work/${next.id.replace(/\.md$/, '')}`} class="no-underline group text-right">
              <p class="text-sm text-text-secondary/70 mb-1">Next &rarr;</p>
              <p class="text-base text-text-primary group-hover:text-text-accent transition-colors">{next.data.company}</p>
            </a>
          ) : <div />}
        </nav>
      )}

      <div class="mt-8 pt-8 border-t border-border-light flex gap-4 flex-wrap">
        <CTA href="/experience">View all experience</CTA>
        <CTA href="/contact" variant="secondary">Contact</CTA>
      </div>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
</Base>
