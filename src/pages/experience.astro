---
import Base from '@/layouts/Base.astro';
import CTA from '@/components/CTA.astro';
import { getCollection } from 'astro:content';

const allSkills = await getCollection('skills');

const domains = [
  'Governance and Accountability',
  'Strategy and Risk',
  'Finance and Operations',
  'People and Culture',
];

const skillsByDomain = domains.map(domain => ({
  domain,
  skills: allSkills
    .filter(s => s.data.domain === domain)
    .sort((a, b) => a.data.category.localeCompare(b.data.category)),
}));

const ratingColour = (rating: string) => {
  switch (rating) {
    case 'Expert': return 'bg-text-accent text-white';
    case 'Practised': return 'bg-bg-dark text-white';
    case 'Awareness': return 'bg-border-light text-text-primary';
    default: return 'bg-border-light text-text-primary';
  }
};

/** Summarise ratings for a domain, e.g. "3 Expert, 1 Practised" */
const ratingSummary = (skills: typeof allSkills) => {
  const counts: Record<string, number> = {};
  for (const s of skills) {
    counts[s.data.rating] = (counts[s.data.rating] || 0) + 1;
  }
  return Object.entries(counts)
    .sort(([a], [b]) => {
      const order = ['Expert', 'Practised', 'Awareness'];
      return order.indexOf(a) - order.indexOf(b);
    })
    .map(([rating, count]) => `${count} ${rating}`)
    .join(', ');
};

const careers = [
  { company: 'Strata Community Insurance', role: 'General Manager, Data and Technology Solutions', scope: 'Mar 2024 to Present. Specialist strata MGA, 90% intermediated. Built data, technology and AI capabilities.' },
  { company: 'Hollard Insurance', role: 'Chief Revenue Officer', scope: 'Sep 2022 to Jun 2023. Transitional role following CBA Insurance acquisition. Board and executive engagement on joint strategy, risk profile and integration.' },
  { company: 'Commonwealth Bank', role: 'General Manager, General Insurance', scope: 'Jan 2015 to Sep 2022. $1bn+ GWP. 700 staff. One million customers. Full P&L and balance sheet accountability.' },
  { company: 'Westpac Banking Corporation', role: 'Senior Management Roles', scope: 'May 2009 to Jan 2015. Three roles across product, operations, and strategy. Portfolio growth, alliance origination.' },
  { company: 'Suncorp and Promina', role: 'Product Manager Roles', scope: 'Jul 2005 to May 2009. Pre-merger Vero portfolio. Post-merger personal lines turnaround. High-net-worth product launch.' },
];
---

<Base
  title="Experience | Miles Sowden"
  description="AICD-aligned skill matrix and career history across five major Australian financial institutions. Governance, strategy, operations and people."
>
  <!-- Intro -->
  <section class="pt-48 pb-16 max-md:pt-32 max-md:pb-12">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h1 class="font-display text-[3.5rem] max-lg:text-5xl max-md:text-[2.5rem] leading-[1.1] tracking-[-0.02em] text-text-primary mb-6">
        Experience
      </h1>
      <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary max-w-[800px]">
        Twenty years leading insurance and financial services businesses across CBA, Westpac, Suncorp, Hollard, and SCI. Full P&L accountability for portfolios exceeding $1 billion, teams of 700, and transformation programs that delivered measurable outcomes in underwriting, digital, culture, and customer experience. Organised below by the four domains of the AICD skills matrix framework.
      </p>
    </div>
  </section>

  <!-- AICD Skill Matrix -->
  <section class="pb-32 max-md:pb-20">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <div class="space-y-16">
        {skillsByDomain.map(({ domain, skills }) => (
          <div>
            <div class="mb-8">
              <h2 class="font-display text-2xl leading-[1.3] text-text-primary border-b-[3px] border-text-accent pb-4 inline-block">
                {domain}
              </h2>
              <p class="text-sm text-text-secondary/70 mt-3">
                {skills.length} skill areas &middot; {ratingSummary(skills)}
              </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {skills.map(skill => (
                <div class="p-8 bg-bg-card">
                  <div class="flex items-start justify-between gap-4 mb-3">
                    <h3 class="font-display text-lg leading-[1.3] text-text-primary">
                      {skill.data.skillArea}
                    </h3>
                    <span class={`text-xs font-medium px-3 py-1 rounded-full flex-shrink-0 ${ratingColour(skill.data.rating)}`}>
                      {skill.data.rating}
                    </span>
                  </div>
                  <p class="text-base leading-relaxed text-text-secondary">{skill.data.headline}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Fit Finder CTA -->
      <div class="mt-16 pt-8 border-t border-border-light">
        <p class="text-xl max-md:text-lg leading-relaxed text-text-secondary mb-6 max-w-[700px]">
          Upload a role description to the Fit Finder to see how these capabilities align, with full evidence and matched case studies for the specific position.
        </p>
        <CTA href="/fit" external={false}>
          Try the Fit Finder
        </CTA>
      </div>
    </div>
  </section>

  <!-- Career timeline -->
  <section class="py-32 max-md:py-20">
    <div class="max-w-[1200px] mx-auto px-12 max-lg:px-8 max-md:px-6">
      <h2 class="font-display text-[2.5rem] max-md:text-[2rem] leading-[1.2] tracking-[-0.02em] text-text-primary mb-12">
        Career
      </h2>
      <div class="space-y-0">
        {careers.map((role) => (
          <div class="border-t border-border-light py-8 grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-4 md:gap-12">
            <div>
              <h3 class="font-display text-xl leading-[1.3] text-text-primary">{role.company}</h3>
            </div>
            <div>
              <p class="text-base text-text-primary font-medium">{role.role}</p>
              <p class="text-base text-text-secondary mt-1">{role.scope}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 pt-8 border-t border-border-light">
        <h3 class="font-display text-xl leading-[1.3] text-text-primary mb-4">Credentials</h3>
        <ul class="text-lg leading-relaxed text-text-secondary space-y-2 list-none pl-0">
          <li>Company Directors Course, Australian Institute of Company Directors (GAICD)</li>
          <li>Certificate in Applied Generative AI for Transformations, Massachusetts Institute of Technology (CertAppGenAI)</li>
          <li>Graduate Diploma of Applied Finance, Financial Services Institute of Australasia (GDipAppFin)</li>
          <li>Bachelor of Business, University of Technology Sydney (BBus)</li>
        </ul>
      </div>
    </div>
  </section>
</Base>
